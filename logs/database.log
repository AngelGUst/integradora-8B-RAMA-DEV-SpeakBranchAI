DEBUG 2026-04-03 22:53:47 django.db.backends debug_sql:151 - (0.109) INSERT INTO "writing_attempts" ("user_id", "question_id", "prompt_text", "student_text", "score_grammar", "score_vocabulary", "score_coherence", "score_spelling", "score", "ai_feedback", "difficulty", "xp_earned", "api_response_raw", "created_at") VALUES (12, 23, 'Write a short paragraph (4–6 sentences) describing your daily routine. 
Use the present simple tense and include at least three time expressions 
(e.g. every morning, at noon, before bed).', 'Every morning I wake up at 7 a.m. and make a cup of coffee before starting work. At noon I usually take a short break to eat lunch and stretch my legs. In the afternoon I continue with my tasks until the evening. Before bed, I like to read a book or review my plans for the next day. This routine helps me stay organized and productive throughout the week.', 90.0, 85.0, 95.0, 95.0, 91.0, 'Tu párrafo está bien estructurado y usa el tiempo presente correctamente. Has incluido suficientes expresiones de tiempo y tu rutina diaria es clara. Sin embargo, podrías mejorar un poco la variedad de vocabulario para hacerlo más interesante.', 'EASY', 9, '{"score_grammar": 90, "score_vocabulary": 85, "score_coherence": 95, "score_spelling": 95, "feedback": "Tu p\u00e1rrafo est\u00e1 bien estructurado y usa el tiempo presente correctamente. Has incluido suficientes expresiones de tiempo y tu rutina diaria es clara. Sin embargo, podr\u00edas mejorar un poco la variedad de vocabulario para hacerlo m\u00e1s interesante."}'::jsonb, '2026-04-04T04:53:47.626631+00:00'::timestamptz) RETURNING "writing_attempts"."id"; args=(12, 23, 'Write a short paragraph (4–6 sentences) describing your daily routine. \nUse the present simple tense and include at least three time expressions \n(e.g. every morning, at noon, before bed).', 'Every morning I wake up at 7 a.m. and make a cup of coffee before starting work. At noon I usually take a short break to eat lunch and stretch my legs. In the afternoon I continue with my tasks until the evening. Before bed, I like to read a book or review my plans for the next day. This routine helps me stay organized and productive throughout the week.', 90.0, 85.0, 95.0, 95.0, 91.0, 'Tu párrafo está bien estructurado y usa el tiempo presente correctamente. Has incluido suficientes expresiones de tiempo y tu rutina diaria es clara. Sin embargo, podrías mejorar un poco la variedad de vocabulario para hacerlo más interesante.', 'EASY', 9, <django.db.backends.postgresql.psycopg_any.Jsonb object at 0x000002C9DA3F57F0>, datetime.datetime(2026, 4, 4, 4, 53, 47, 626631, tzinfo=datetime.timezone.utc)); alias=default
